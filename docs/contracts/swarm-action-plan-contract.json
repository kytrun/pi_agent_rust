{
  "schema": "pi.swarm.action_plan_contract.v1",
  "action_plan_schema": "pi.swarm.action_plan.v1",
  "purpose": "dry_run_swarm_action_plan_not_source_of_truth",
  "description": "Contract for the dry-run swarm action plan projection. The artifact classifies the next safest operator action from captured Beads, git, RCH, validation, and Agent Mail evidence without mutating those sources.",
  "allowed_statuses": [
    "ready",
    "degraded",
    "blocked"
  ],
  "allowed_decisions": [
    "implement_ready_work",
    "create_or_refine_beads",
    "renew_stale_evidence",
    "wait_for_pressure",
    "pause_or_surface_blocker"
  ],
  "command_safety_classes": [
    "read_only_probe",
    "coordination_probe",
    "validation_probe",
    "evidence_capture",
    "beads_mutation_requires_operator"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "source_plan_schema",
    "input_pack_schema",
    "input_pack_status",
    "next_safest_action",
    "operator_actions",
    "failure_actions",
    "source_statuses",
    "source_classification",
    "degraded_reasons",
    "forbidden_actions",
    "planner_guards",
    "redaction_summary"
  ],
  "required_next_action_fields": [
    "decision",
    "source_action",
    "rank",
    "title",
    "severity",
    "confidence",
    "rationale",
    "evidence_paths",
    "command_safety_classes",
    "commands_require_operator_execution"
  ],
  "required_true_guards": [
    "dry_run_only",
    "no_source_mutation",
    "commands_require_operator_execution",
    "dangerous_runnable_commands_blocked",
    "output_overwrite_refusal"
  ],
  "required_forbidden_actions": [
    "destructive git reset",
    "destructive git clean",
    "recursive filesystem deletion",
    "file deletion",
    "automatic commit",
    "automatic file reservation"
  ],
  "authority_boundary": {
    "does_not_replace": [
      "Beads",
      "Agent Mail",
      "git",
      "RCH",
      "validation broker",
      "doctor",
      "CI",
      "human operator judgment"
    ],
    "may_recommend_only": true,
    "must_not_execute_commands": true,
    "must_refuse_output_overwrite": true
  },
  "required_replay_scenarios": [
    "healthy_ready_claim",
    "empty_ready_queue",
    "deferred_roadmap_backlog",
    "degraded_agent_mail_soft_lock",
    "saturated_rch_queue",
    "unrelated_dirty_worktree",
    "stale_action_plan_evidence",
    "validation_failure_fail_closed"
  ]
}
