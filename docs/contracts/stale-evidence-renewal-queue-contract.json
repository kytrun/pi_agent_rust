{
  "schema": "pi.swarm.stale_evidence_renewal_queue_contract.v1",
  "queue_schema": "pi.swarm.stale_evidence_renewal_queue.v1",
  "purpose": "operator_guidance_not_auto_regeneration",
  "description": "Contract for a read-only stale-evidence renewal queue. The queue may recommend bounded operator commands for stale, missing, contract-drifted, or RCH-blocked evidence, but it must not regenerate artifacts, overwrite evidence, run heavy validation, mutate coordination state, or weaken drop-in release gates.",
  "allowed_statuses": [
    "ready",
    "degraded",
    "blocked"
  ],
  "allowed_item_statuses": [
    "fresh",
    "renewal_recommended",
    "blocked"
  ],
  "reason_codes": [
    "fresh",
    "expired",
    "missing_source_ref",
    "contract_schema_changed",
    "contract_newer_than_artifact",
    "blocked_rch",
    "known_safe_renewal_command",
    "malformed_json",
    "missing_generated_at"
  ],
  "operator_command_safety_classes": [
    "read_only_probe",
    "evidence_capture",
    "validation_probe",
    "contract_review",
    "manual_regeneration_requires_operator",
    "rch_blocked_wait"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "source_root",
    "freshness_window_hours",
    "summary",
    "queue",
    "fresh_samples",
    "action_plan_integration",
    "runpack_integration",
    "guardrails",
    "forbidden_actions"
  ],
  "required_true_guardrails": [
    "dry_run_only",
    "no_source_mutation",
    "no_output_overwrite",
    "no_heavy_validation_auto_run",
    "commands_require_operator_execution",
    "dropin_claim_gate_preserved"
  ],
  "required_forbidden_actions": [
    "automatic evidence regeneration",
    "automatic evidence overwrite",
    "heavy validation auto-run",
    "drop-in release gate override",
    "network fetch",
    "file deletion",
    "git mutation",
    "Beads mutation",
    "Agent Mail mutation"
  ],
  "required_fixture_scenarios": [
    "fresh_evidence",
    "expired_evidence",
    "missing_source_refs",
    "changed_contract_schema",
    "blocked_rch",
    "known_safe_renewal_commands"
  ],
  "authority_boundary": {
    "does_not_replace": [
      "Beads",
      "Agent Mail",
      "git",
      "RCH",
      "validation broker",
      "drop-in certification verdict",
      "CI",
      "human operator judgment"
    ],
    "may_recommend_only": true,
    "must_not_execute_commands": true,
    "must_refuse_output_overwrite": true,
    "must_not_weaken_dropin_claim_gate": true
  }
}
