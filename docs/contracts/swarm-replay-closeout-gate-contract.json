{
  "schema": "pi.swarm.replay_closeout_gate_contract.v1",
  "decision_gate_schema": "pi.swarm.replay_closeout_gate.v1",
  "purpose": "prompt_to_artifact_swarm_replay_closeout_gate_not_source_of_truth",
  "allowed_statuses": [
    "pass",
    "fail"
  ],
  "allowed_check_statuses": [
    "pass",
    "fail"
  ],
  "allowed_decisions": [
    "close_final_gate_and_parent_epic",
    "file_follow_up_beads_before_closing_epic"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "parent_epic",
    "final_gate_bead",
    "required_checks",
    "child_artifact_map",
    "quality_gate_results",
    "checklist",
    "missing_checks",
    "follow_up_required",
    "follow_up_beads",
    "decision",
    "epic_can_close_after_this_commit"
  ],
  "required_child_bead_ids": [
    "bd-in57w.1",
    "bd-in57w.2",
    "bd-in57w.3",
    "bd-in57w.4",
    "bd-in57w.5",
    "bd-in57w.6",
    "bd-in57w.7",
    "bd-in57w.8",
    "bd-in57w.9",
    "bd-in57w.10",
    "bd-in57w.11"
  ],
  "required_check_ids": [
    "child_beads_closed",
    "trace_contract",
    "ingestor_normalizer",
    "replay_engine",
    "policy_adapters",
    "policy_metrics",
    "fault_corpus",
    "large_host_budgets",
    "preview_runpack_integration",
    "no_mock_e2e",
    "performance_evidence",
    "operator_docs",
    "readme_freshness",
    "pushed_commits",
    "quality_gates"
  ],
  "required_quality_gate_ids": [
    "json_contracts",
    "docs_purpose_headers",
    "readme_evidence_freshness",
    "swarm_replay_trace_contract_rch",
    "swarm_replay_ingestor_rch",
    "swarm_replay_preview_cli_rch",
    "swarm_replay_closeout_gate_contract_rch",
    "cargo_fmt",
    "cargo_check_all_targets_rch",
    "cargo_clippy_all_targets_rch",
    "staged_ubs",
    "beads_ledger_reconcile"
  ],
  "requirements": [
    {
      "id": "child_artifact_mapping",
      "description": "Every implementation child bead maps to committed code paths, test paths, docs or evidence paths, validation commands, close reason, and commit hash."
    },
    {
      "id": "prompt_to_artifact_coverage",
      "description": "The checklist covers the trace contract, ingestor, deterministic replay engine, policy adapters, policy metrics, fault corpus, large-host budgets, CLI/runpack integration, no-mock E2E, performance evidence, operator docs, README freshness, pushed refs, and quality gates."
    },
    {
      "id": "safe_close_behavior",
      "description": "A passing gate may close the final gate and parent epic. A failing gate must emit follow-up Beads instead of optimistic closeout."
    },
    {
      "id": "rch_heavy_gates",
      "description": "All heavy Cargo validation evidence must prove RCH execution, including focused replay tests plus cargo check and clippy."
    },
    {
      "id": "not_source_of_truth",
      "description": "The closeout gate is evidence over Beads, git, docs, tests, RCH, runpacks, and source artifacts. It does not replace those sources of truth."
    }
  ]
}
